# BrioCare live demo — copy this file to `.env` and fill in the keys you have.
# Both are OPTIONAL: with neither set, the demo still runs (no video; notes show the
# raw transcript). `.env` is gitignored, so your keys are never committed.

# Daily.co — enables the live video/audio call between the therapist and the kid.
# Get one at https://dashboard.daily.co  (Developers → API keys).
DAILY_API_KEY=

# Anthropic (Claude) — enables AI session notes + warmer shared-prompt wording.
# Get one at https://console.anthropic.com  (Settings → API keys).
ANTHROPIC_API_KEY=
